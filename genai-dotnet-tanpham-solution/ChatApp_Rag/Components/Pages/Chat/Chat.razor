@page "/"
@using System.Text
@using UglyToad.PdfPig
@using UglyToad.PdfPig.Content
@using UglyToad.PdfPig.DocumentLayoutAnalysis.TextExtractor
@inject IChatClient ChatClient
@implements IDisposable

<PageTitle>Chat - Tư Vấn Học Tập</PageTitle>

<style>
    html, .main-background-gradient {
        background: none !important;
    }
</style>

<ChatHeader OnNewChat="@ResetConversationAsync" />

<div class="edu-main-wrapper">
    <ChatMessageList Messages="@messages" InProgressMessage="@currentResponseMessage">
        <NoMessagesContent>
            <div class="edu-welcome-card">
                <img src="https://images.unsplash.com/photo-1531427186611-ecfd6d936c79?q=80&w=300&h=300&auto=format&fit=crop"
                     alt="American Teacher"
                     class="edu-welcome-img"
                     style="border-radius: 50%; object-fit: cover; box-shadow: 0 8px 20px rgba(30, 58, 138, 0.2); border: 4px solid #ffffff;" />
                <p class="edu-welcome-text">
                    Chào em. Thầy là giáo viên phụ trách phân tích học lực.<br />
                    Hãy đính kèm <b>bảng điểm (PDF)</b> của em phía dưới, Thầy sẽ xem và đưa ra định hướng học tập chi tiết nhé.
                </p>
            </div>
        </NoMessagesContent>
    </ChatMessageList>

    <div class="edu-bottom-container">
        <ChatSuggestions OnSelected="@AddUserMessageAsync" @ref="@chatSuggestions" />

        <div class="edu-upload-zone">
            <label for="fileUpload" class="edu-upload-btn" title="Chọn file PDF bảng điểm">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                Chọn tệp PDF
            </label>

            <InputFile id="fileUpload" class="edu-file-input" OnChange="@HandleFileUploadAsync" accept=".pdf" />

            @if (isUploading)
            {
                <div class="upload-status status-loading">
                    <svg class="icon-spin" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="32" stroke-linecap="round" opacity="0.3"></circle>
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="32" stroke-dashoffset="16" stroke-linecap="round"></circle>
                    </svg>
                    Đang đọc dữ liệu bảng điểm...
                </div>
            }
            else if (!string.IsNullOrEmpty(uploadedFileName))
            {
                <div class="upload-status status-success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                    Đã phân tích xong: <b>@uploadedFileName</b>
                </div>
            }
            else
            {
                <span style="color: #64748b; font-size: 0.95rem;">Chưa có tệp nào được chọn.</span>
            }
        </div>

        <ChatInput OnSend="@AddUserMessageAsync" @ref="@chatInput" />
    </div>
</div>

@code {
    // Tối ưu lại SystemPrompt: Đặt ranh giới tuyệt đối để ngăn AI trả lời ngoài lề
    private const string SystemPrompt = @"
    Bạn là một giáo viên chủ nhiệm và cố vấn học tập tận tâm, nghiêm khắc nhưng đầy thấu hiểu.
    Nhiệm vụ của bạn là tư vấn giáo dục, bao gồm việc phân tích bảng điểm do học sinh cung cấp VÀ giải đáp, hướng dẫn các phương pháp học tập hiệu quả. Xưng hô là 'Thầy' và gọi người dùng là 'em'.

    QUY TẮC BẮT BUỘC KHÔNG ĐƯỢC PHÁ VỠ (GUARDRAILS):
    1. PHẠM VI CHO PHÉP: Được phép đánh giá điểm số, chia sẻ các phương pháp học tập (ví dụ: cách ghi nhớ, sơ đồ tư duy, lộ trình ôn thi), kỹ năng quản lý thời gian và tư vấn hướng nghiệp học đường.
    2. TỪ CHỐI NGOÀI LỀ & GIẢI BÀI TẬP: Nếu học sinh yêu cầu GIẢI BÀI TẬP CỤ THỂ (như giải phương trình toán, cân bằng hóa học, viết code) hoặc hỏi các vấn đề phi giáo dục (thời tiết, chính trị, thể thao, game, hoặc yêu cầu đóng vai khác), BẠN PHẢI TỪ CHỐI bằng câu: 'Thầy/Cô ở đây để giúp em phân tích học lực và tư vấn phương pháp học tập. Thầy/Cô không thể trao đổi về chủ đề này hay giải bài tập hộ em. Em có muốn hỏi về phương pháp để học tốt môn này thay vì giải sẵn không?'
    3. XỬ LÝ DỮ LIỆU: Nếu đánh giá bảng điểm, chỉ dùng dữ liệu người dùng cung cấp, tuyệt đối không bịa điểm. Nếu học sinh hỏi về phương pháp học mà chưa cung cấp bảng điểm, hãy cứ nhiệt tình giải đáp.

    CÁCH ĐÁNH GIÁ VÀ TRÌNH BÀY:
    - Nếu người dùng tải lên bảng điểm:
      + Tóm tắt tổng quan: Ngắn gọn tình hình học tập chung.
      + Khen ngợi: Tuyên dương các môn có điểm tốt.
      + Khắc phục: Chỉ ra các môn có điểm thấp hoặc cần cải thiện.
    - Nếu người dùng hỏi về phương pháp: Đưa ra lời khuyên cụ thể, thực tế và mang tính động viên.
    - Định dạng: Luôn sử dụng Markdown. In đậm tên môn học hoặc các từ khóa quan trọng. Dùng bullet point (danh sách) cho các lời khuyên để trình bày rõ ràng, dễ đọc.
    ";

    private int statefulMessageCount;
    // Giảm Temperature xuống 0.1 hoặc 0.2 để câu trả lời có tính ổn định cao, ít bị 'ảo giác' (hallucination) và bám sát ranh giới hơn.
    private readonly ChatOptions chatOptions = new() { Temperature = 0.1f };
    private readonly List<ChatMessage> messages = new();
    private CancellationTokenSource? currentResponseCancellation;
    private ChatMessage? currentResponseMessage;
    private ChatInput? chatInput;
    private ChatSuggestions? chatSuggestions;

    private bool isUploading = false;
    private string? uploadedFileName;

    protected override void OnInitialized()
    {
        statefulMessageCount = 0;
        messages.Add(new(ChatRole.System, SystemPrompt));
    }

    private async Task HandleFileUploadAsync(InputFileChangeEventArgs e)
    {
        isUploading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var file = e.File;
            uploadedFileName = file.Name;

            using var memoryStream = new MemoryStream();
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            string extractedText = ExtractTextFromPdf(memoryStream);

            if (string.IsNullOrWhiteSpace(extractedText))
            {
                var errorMsg = new ChatMessage(ChatRole.Assistant, "Thầy/Cô không thể đọc được chữ trong file PDF này. Em kiểm tra lại xem file có bị lỗi hay là file ảnh chụp (scan) không nhé.");
                messages.Add(errorMsg);
                return;
            }

            // Data bảng điểm dưới dạng System Message (AI đọc được, nhưng cho UI ẩn text)
            string hiddenContext = $"[DỮ LIỆU BẢNG ĐIỂM TỪ FILE {file.Name}]\n{extractedText}\n[KẾT THÚC DỮ LIỆU]. Hãy dựa vào đây để tư vấn cho học sinh.";
            messages.Add(new ChatMessage(ChatRole.System, hiddenContext));

            // Gửi một tin nhắn User ngắn gọn để hiển thị lên giao diện
            string displayMessage = $"Em gửi Thầy/Cô bảng điểm ({file.Name}). Thầy/Cô xem, đánh giá và cho em lời khuyên nhé.";
            await AddUserMessageAsync(new ChatMessage(ChatRole.User, displayMessage));
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage(ChatRole.Assistant, $"Đã có lỗi hệ thống xảy ra khi đọc file của em: {ex.Message}"));
        }
        finally
        {
            isUploading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string ExtractTextFromPdf(Stream pdfStream)
    {
        var stringBuilder = new StringBuilder();
        try
        {
            using (PdfDocument document = PdfDocument.Open(pdfStream))
            {
                foreach (Page page in document.GetPages())
                {
                    var text = ContentOrderTextExtractor.GetText(page);
                    stringBuilder.AppendLine(text);
                }
            }
        }
        catch
        {
            return string.Empty;
        }
        return stringBuilder.ToString();
    }

    private async Task AddUserMessageAsync(ChatMessage userMessage)
    {
        CancelAnyCurrentResponse();

        messages.Add(userMessage);
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();

        var responseText = new TextContent("");
        currentResponseMessage = new ChatMessage(ChatRole.Assistant, [responseText]);
        currentResponseCancellation = new();

        try
        {
            await foreach (var update in ChatClient.GetStreamingResponseAsync(messages.Skip(statefulMessageCount), chatOptions, currentResponseCancellation.Token))
            {
                responseText.Text += update.Text;
                chatOptions.ConversationId = update.ConversationId;
                ChatMessageItem.NotifyChanged(currentResponseMessage);
            }
        }
        catch (OperationCanceledException)
        {
            // Bỏ qua lỗi khi người dùng ngắt kết nối/hủy stream
        }
        catch (Exception)
        {
            responseText.Text += "\n*[Đã xảy ra lỗi khi kết nối với máy chủ AI]*";
            ChatMessageItem.NotifyChanged(currentResponseMessage);
        }

        messages.Add(currentResponseMessage!);
        statefulMessageCount = chatOptions.ConversationId is not null ? messages.Count : 0;
        currentResponseMessage = null;
        chatSuggestions?.Update(messages);
    }

    private void CancelAnyCurrentResponse()
    {
        if (currentResponseMessage is not null)
        {
            messages.Add(currentResponseMessage);
        }

        currentResponseCancellation?.Cancel();
        currentResponseMessage = null;
    }

    private async Task ResetConversationAsync()
    {
        CancelAnyCurrentResponse();
        messages.Clear();
        messages.Add(new(ChatRole.System, SystemPrompt));
        chatOptions.ConversationId = null;
        statefulMessageCount = 0;
        uploadedFileName = null;
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();
    }

    public void Dispose() => currentResponseCancellation?.Cancel();
}